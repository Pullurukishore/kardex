<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Batch {{batchNumber}} Review Complete</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #f0f4f8;
            color: #2d3748;
            padding: 30px 10px;
        }

        .wrapper {
            max-width: 600px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }

        .header {
            background: linear-gradient(135deg, #1a56a0 0%, #0e3a72 100%);
            padding: 32px 36px;
            text-align: center;
        }

        .header h1 {
            color: #ffffff;
            font-size: 22px;
            font-weight: 700;
        }

        .header .batch-num {
            display: inline-block;
            background: rgba(255, 255, 255, 0.2);
            color: #fff;
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
            margin-top: 10px;
            letter-spacing: 1px;
        }

        .status-banner {
            text-align: center;
            padding: 22px 36px;
        }

        .badge {
            display: inline-block;
            padding: 8px 22px;
            border-radius: 24px;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .badge-approved {
            background-color: #d1fae5;
            color: #065f46;
        }

        .badge-partial {
            background-color: #fef3c7;
            color: #92400e;
        }

        .badge-rejected {
            background-color: #fee2e2;
            color: #991b1b;
        }

        .summary-strip {
            display: flex;
            background: #ebf4ff;
            border-top: 1px solid #bee3f8;
            border-bottom: 1px solid #bee3f8;
        }

        .summary-cell {
            flex: 1;
            padding: 14px;
            text-align: center;
            border-right: 1px solid #bee3f8;
        }

        .summary-cell:last-child {
            border-right: none;
        }

        .summary-label {
            font-size: 11px;
            color: #4a90d9;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .summary-value {
            font-size: 18px;
            font-weight: 800;
            color: #1a56a0;
            margin-top: 4px;
        }

        .content {
            padding: 28px 36px;
        }

        .greeting {
            font-size: 15px;
            color: #4a5568;
            margin-bottom: 18px;
        }

        .info-card {
            background: #f7fafc;
            border: 1px solid #e2e8f0;
            border-left: 4px solid #1a56a0;
            border-radius: 6px;
            padding: 18px 20px;
            margin: 20px 0;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 7px 0;
            border-bottom: 1px solid #edf2f7;
            font-size: 14px;
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-label {
            color: #718096;
            font-weight: 600;
            min-width: 140px;
        }

        .info-value {
            color: #2d3748;
            text-align: right;
            font-weight: 500;
        }

        .notes-box {
            background: #fffbeb;
            border: 1px solid #fcd34d;
            border-radius: 6px;
            padding: 14px 18px;
            margin: 18px 0;
            font-size: 14px;
            color: #92400e;
            line-height: 1.6;
        }

        .notes-box strong {
            display: block;
            margin-bottom: 6px;
        }

        .next-step {
            font-size: 13px;
            color: #718096;
            margin-top: 18px;
            line-height: 1.7;
            background: #f7fafc;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            padding: 14px 16px;
        }

        .footer {
            background: #f7fafc;
            border-top: 1px solid #e2e8f0;
            text-align: center;
            padding: 18px 36px;
            font-size: 12px;
            color: #a0aec0;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="header">
            <h1>💳 Payment Batch Review Complete</h1>
            <div class="batch-num">{{batchNumber}}</div>
        </div>

        <div class="status-banner">
            {{#if isApproved}}
            <span class="badge badge-approved">✅ Fully Approved</span>
            {{/if}}
            {{#if isPartial}}
            <span class="badge badge-partial">⚠️ Partially Approved</span>
            {{/if}}
            {{#if isRejected}}
            <span class="badge badge-rejected">❌ Rejected</span>
            {{/if}}
        </div>

        <!-- Summary strip -->
        <div class="summary-strip">
            <div class="summary-cell">
                <div class="summary-label">Approved Items</div>
                <div class="summary-value">{{approvedItems}} / {{totalItems}}</div>
            </div>
            <div class="summary-cell">
                <div class="summary-label">Approved Amount</div>
                <div class="summary-value">{{currency}} {{approvedAmount}}</div>
            </div>
        </div>

        <div class="content">
            <p class="greeting">Hello <strong>{{requesterName}}</strong>,</p>
            <p style="font-size:14px;color:#4a5568;line-height:1.7;">
                Your payment batch <strong>{{batchNumber}}</strong> has been reviewed by the Finance Admin.
                The overall decision is <strong>{{batchStatus}}</strong>.
            </p>

            <div class="info-card">
                <div class="info-row">
                    <span class="info-label">Batch Number</span>
                    <span class="info-value">{{batchNumber}}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Overall Status</span>
                    <span class="info-value">{{batchStatus}}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Approved Items</span>
                    <span class="info-value">{{approvedItems}} of {{totalItems}}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Approved Amount</span>
                    <span class="info-value">{{currency}} {{approvedAmount}}</span>
                </div>
            </div>

            {{#if reviewNotes}}
            <div class="notes-box">
                <strong>💬 Admin Review Notes:</strong>
                {{reviewNotes}}
            </div>
            {{/if}}

            <div class="next-step">
                {{#if isApproved}}
                🎉 All items were approved. You can now download the payment file from the Finance Portal.
                {{/if}}
                {{#if isPartial}}
                ⚠️ Some items were rejected. You can download the approved items from the Finance Portal. Please
                re-submit the rejected items after correction.
                {{/if}}
                {{#if isRejected}}
                ❌ All items were rejected. Please review the admin notes, make necessary corrections, and re-submit the
                batch.
                {{/if}}
            </div>
        </div>

        <div class="footer">
            <p>This is an automated message – please do not reply directly to this email.</p>
            <p>© {{currentYear}} KardexCare. All rights reserved.</p>
        </div>
    </div>
</body>

</html>